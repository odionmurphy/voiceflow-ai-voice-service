# Server
PORT=4001
NODE_ENV=development

# Shares the same Postgres database as the main backend
DATABASE_URL=postgresql://voiceflow:voiceflow_dev_pw@localhost:5432/voiceflow_ai

# Gemini API (free tier) - get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Twilio - find these in your Twilio Console dashboard. TWILIO_AUTH_TOKEN validates
# incoming webhook signatures; TWILIO_ACCOUNT_SID is also required for outbound calling
# (automatic follow-ups below).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Set to "true" once your server is on a real HTTPS URL (ngrok/production).
# Keep "false" for quick local testing to skip signature validation.
VALIDATE_TWILIO_SIGNATURE=false

# The public URL Twilio will reach this server on (ngrok URL while testing,
# your real domain in production). Used to build the correct action URLs.
PUBLIC_BASE_URL=http://localhost:4001

# Automatic follow-up calls: if a caller wanted to book but the call ended without one,
# call them back later and try again. Off by default - THIS PLACES REAL, BILLED OUTBOUND
# PHONE CALLS once enabled. Only set to "true" once you've decided your business actually
# wants this (and ideally have consent language for it).
FOLLOWUP_CALLS_ENABLED=false
# Minutes to wait after the original call before attempting a follow-up.
FOLLOWUP_DELAY_MINUTES=15
# How often (minutes) to scan for calls needing a follow-up.
FOLLOWUP_POLL_MINUTES=15

# Sentry error monitoring. Free tier at sentry.io. Leave blank to disable.
SENTRY_DSN=
